# Dashboard — Python + Flask serving static HTML
FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY state.py config.py pipeline.py telegram_bot.py scheduler.py ./
COPY agents/ agents/
COPY assets/ assets/
COPY dashboard/ dashboard/
COPY references/ references/

RUN mkdir -p /app/output /app/references/patterns

CMD ["python", "dashboard/app.py"]
